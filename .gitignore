# =============================================================================
# Data — raw DAIC-WOZ files (large, not to be committed)
# =============================================================================
data/transcripts/
data/labels/
data/raw/
data/processed/

# Keep the processed/ directory structure but not contents
!data/processed/.gitkeep
!data/labels/.gitkeep

# =============================================================================
# Trained models (large binary files — use DVC or similar if needed)
# =============================================================================
models/
results/models/
*.joblib
*.pkl
*.pickle

# =============================================================================
# Result figures (regenerated by train_classical.py)
# =============================================================================
results/figures/

# Allow the results CSV to be committed (small, useful for tracking progress)
!results/results_classical.csv
!results/labels.csv

